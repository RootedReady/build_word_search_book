      "extra_dirs": [
        "numpy.libs"
      ]
    },
    {
      "name": "pandas",
      "version": "3.0.1",
      "required": true,
      "arch_specific": true,
      "wheel_x64": "pandas-3.0.1-cp312-cp312-win_amd64.whl",
      "wheel_x86": "pandas-3.0.1-cp312-cp312-win32.whl",
      "url_x64": "https://github.com/RootedReady/build_word_search_book/raw/refs/heads/main/packages/pandas/pandas-3.0.1-cp312-cp312-win_amd64.whl",
