      "wheel_x86": "pillow-12.0.0-cp312-cp312-win32.whl",
      "url_x64": "https://github.com/RootedReady/build_word_search_book/raw/refs/heads/main/packages/pillow/pillow-12.0.0-cp312-cp312-win_amd64.whl",
      "url_x86": "https://github.com/RootedReady/build_word_search_book/raw/refs/heads/main/packages/pillow/pillow-12.0.0-cp312-cp312-win32.whl"
