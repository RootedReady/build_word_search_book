    {
      "name": "cffi",
      "version": "2.0.0",
      "required": false,
      "arch_specific": true,
      "wheel_x64": "cffi-2.0.0-cp312-cp312-win_amd64.whl",
      "wheel_x86": "cffi-2.0.0-cp312-cp312-win32.whl",
