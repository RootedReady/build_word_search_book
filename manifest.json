  "runtime_libs": {
    "description": "GTK/Cairo native libraries for SVG support (optional)",
    "required_for": [
      "svglib",
      "cairosvg",
      "cairocffi"
    ],
    "optional": true,
    "x64": {
      "base_url": "https://github.com/RootedReady/build_word_search_book/raw/main/runtime/x64/",
      "files": [
        "libcairo-2.dll",
        "libcairo-gobject-2.dll",
        "libpng16-16.dll",
        "libffi-7.dll",
        "zlib1.dll",
        "libglib-2.0-0.dll",
        "libgobject-2.0-0.dll",
        "libfontconfig-1.dll"
      ]
    },
    "x86": {
      "base_url": "https://github.com/RootedReady/build_word_search_book/raw/main/runtime/x86/",
      "files": [
        "libcairo-2.dll",
        "libcairo-gobject-2.dll",
        "libpng16-16.dll",
        "libffi-7.dll",
        "zlib1.dll",
        "libglib-2.0-0.dll",
        "libgobject-2.0-0.dll",
        "libfontconfig-1.dll"
      ]
    },
    "install_location": "bin/"
  }
