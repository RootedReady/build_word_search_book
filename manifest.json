      "version": "1.6.0",
      "required": false,
      "wheel": "svglib-1.6.0-py3-none-any.whl",
      "url": "https://github.com/RootedReady/build_word_search_book/raw/refs/heads/main/packages/svglib/svglib-1.6.0-py3-none-any.whl"
    },
    {
      "name": "cairosvg",
      "version": "2.8.2",
      "required": false,
      "wheel": "cairosvg-2.8.2-py3-none-any.whl",
      "url": "https://github.com/RootedReady/build_word_search_book/raw/refs/heads/main/packages/cairosvg/cairosvg-2.8.2-py3-none-any.whl"
    },
    {
      "name": "cairocffi",
      "version": "1.7.1",
      "required": false,
      "wheel": "cairocffi-1.7.1-py3-none-any.whl",
